# ── Stage 1: builder ─────────────────────────────────────────────────────────
# vLLM runs as a separate sidecar container and is accessed via the OpenAI-
# compatible HTTP API. This image installs base deps only (no vllm extra).
FROM python:3.11-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Install build backend first so hatchling is available for the wheel build
RUN pip install --no-cache-dir hatchling

# Copy project definition then full source
COPY pyproject.toml ./
COPY . .

# Install base deps only — vLLM/torch are NOT installed here; the vLLM sidecar
# exposes an OpenAI-compatible endpoint consumed via the openai client.
RUN pip install --no-cache-dir .

# ── Stage 2: runtime ─────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# URL of the vLLM sidecar container (override at runtime via env or compose)
ENV VLLM_BASE_URL=http://vllm:8000

# Bring in installed packages and console scripts from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Non-root user
RUN adduser --uid 1000 --disabled-password --gecos "" axon

WORKDIR /app

# Copy application source so hatchling src layout resolution works at runtime
COPY . .

RUN chown -R axon:axon /app
USER axon

EXPOSE 8092

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8092/health || exit 1

CMD ["axon-narrative-miner"]
