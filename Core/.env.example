# axon-graph — environment variable overrides
# Copy to .env and fill in values before running.
# All variables are prefixed with AXON_ at runtime.

# ── Network ──────────────────────────────────────────────────────────────────
# AXON_NETUID=42                    # Bittensor subnet UID
# AXON_NETWORK=finney               # finney | test | local

# ── Embedding model ───────────────────────────────────────────────────────────
# AXON_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── Domain miner ─────────────────────────────────────────────────────────────
# AXON_DOMAIN_MINER_TOP_K=5
# AXON_MINER_AXON_PORT=8091
# AXON_CHUNK_CHALLENGE_PORT=8092

# ── Narrative miner ───────────────────────────────────────────────────────────
# AXON_NARRATIVE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# AXON_NARRATIVE_MAX_TOKENS=400
# AXON_NARRATIVE_AXON_PORT=8093
# VLLM_BASE_URL=http://localhost:8000/v1

# ── Validator ─────────────────────────────────────────────────────────────────
# AXON_VALIDATOR_SAMPLE_SIZE=16

# ── Redis (graph store + session cache) ─────────────────────────────────────
# AXON_GRAPH_REDIS_HOST=localhost
# AXON_GRAPH_REDIS_PORT=6379
# AXON_GRAPH_REDIS_DB=0
# AXON_SESSION_REDIS_DB=1

# ── Orchestrator gateway ───────────────────────────────────────────────────
# AXON_ORCHESTRATOR_HOST=0.0.0.0
# AXON_ORCHESTRATOR_PORT=8080
# AXON_MAX_CONCURRENT_SESSIONS=500

# ── Evolution ────────────────────────────────────────────────────────────────
# AXON_BOND_ESCROW_ADDRESS=<ss58 address of the bond escrow wallet>

# ── Bittensor wallet (set via btcli or env) ──────────────────────────────────
# BT_WALLET_NAME=default
# BT_WALLET_HOTKEY=default
